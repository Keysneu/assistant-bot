# vLLM extreme stress profile (single GPU)
# Usage:
#   set -a && source deploy/vllm/.env.extreme.example && set +a
#   bash deploy/vllm/start_vllm.sh

MODEL_NAME=google/gemma-4-E4B-it
SERVED_MODEL_NAME=gemma4-e4b-it
PORT=8100
HOST=0.0.0.0
API_KEY=EMPTY

# Aggressive utilization for stress test
GPU_MEMORY_UTILIZATION=0.99
MAX_MODEL_LEN=16384
MAX_NUM_SEQS=48
MAX_NUM_BATCHED_TOKENS=262144
ENABLE_ASYNC_SCHEDULING=1
GENERATION_CONFIG=vllm

# Extreme profile disables prefix-cache for fair KV pressure visibility
DEPLOY_PROFILE=extreme
DISABLE_PREFIX_CACHING=1
ENABLE_REASONING=0
ENABLE_TOOL_CALLING=0

# Text-only budget for maximum text throughput
LIMIT_MM_PER_PROMPT='{"image":0,"audio":0}'

# Optional advanced args
TENSOR_PARALLEL_SIZE=
MM_PROCESSOR_KWARGS=
