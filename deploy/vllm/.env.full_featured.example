# vLLM Gemma4 official full-featured profile (adapted for E4B)
# Usage:
#   set -a && source deploy/vllm/.env.full_featured.example && set +a
#   bash deploy/vllm/start_vllm.sh

MODEL_NAME=google/gemma-4-E4B-it
SERVED_MODEL_NAME=gemma4-e4b-it
PORT=8100
HOST=0.0.0.0
API_KEY=EMPTY

# Official full-featured flags (model kept on E4B)
GPU_MEMORY_UTILIZATION=0.98
MAX_MODEL_LEN=16384
TENSOR_PARALLEL_SIZE=
ENABLE_ASYNC_SCHEDULING=1
DEPLOY_PROFILE=full_featured

# Keep high-throughput headroom for normal use
MAX_NUM_SEQS=32
MAX_NUM_BATCHED_TOKENS=131072
GENERATION_CONFIG=vllm

# Enable full Gemma4 capabilities
ENABLE_REASONING=1
ENABLE_TOOL_CALLING=1
LIMIT_MM_PER_PROMPT='{"image":4,"audio":1,"video":1}'

# Optional advanced args (JSON string)
MM_PROCESSOR_KWARGS=
