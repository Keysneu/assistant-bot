# vLLM server runtime
MODEL_NAME=google/gemma-4-E4B-it
SERVED_MODEL_NAME=gemma4-e4b-it
PORT=8100
HOST=0.0.0.0
API_KEY=EMPTY
GPU_MEMORY_UTILIZATION=0.98
MAX_MODEL_LEN=16384
MAX_NUM_SEQS=32
# 大批处理上限（高并发高负载）
MAX_NUM_BATCHED_TOKENS=131072
ENABLE_ASYNC_SCHEDULING=1
GENERATION_CONFIG=vllm
# 部署档位: rag_text | vision | full | full_featured | benchmark | extreme
DEPLOY_PROFILE=full_featured
# 当 DEPLOY_PROFILE=benchmark 时会自动开启
DISABLE_PREFIX_CACHING=0
# Gemma4 reasoning / tool calling 开关
ENABLE_REASONING=1
ENABLE_TOOL_CALLING=1
# 多卡时可设置, 单卡留空
TENSOR_PARALLEL_SIZE=
# 动态视觉分辨率等参数（JSON 字符串），例如 {"max_pixels":1280}
MM_PROCESSOR_KWARGS=
# vLLM 新版建议使用 JSON 格式
# 文本场景建议: {"image":0,"audio":0,"video":0}
# 图像场景建议: {"image":2,"audio":0,"video":0}
# 视频场景建议: {"image":4,"audio":1,"video":1}
# 兼容旧格式: image=2,audio=0,video=0（脚本会自动转换）
LIMIT_MM_PER_PROMPT='{"image":4,"audio":1,"video":1}'

# 官方 full-featured 参数适配（E4B）：
# DEPLOY_PROFILE=full_featured
# MODEL_NAME=google/gemma-4-E4B-it
# SERVED_MODEL_NAME=gemma4-e4b-it

# Backend (assistant-bot) side
LLM_PROVIDER=vllm
VLLM_BASE_URL=http://127.0.0.1:8100/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=gemma4-e4b-it
