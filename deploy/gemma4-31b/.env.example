# vLLM server runtime - Gemma-4-31B-IT-AWQ
MODEL_NAME=QuantTrio/gemma-4-31B-it-AWQ
SERVED_MODEL_NAME=gemma4-31b-it-awq
PORT=6008
HOST=0.0.0.0
API_KEY=EMPTY

# 👇 需要修改的关键参数 👇
GPU_MEMORY_UTILIZATION=0.80     # 降低到 0.9，给 PyTorch 留出更多临时计算空间
MAX_MODEL_LEN=4096              # 从 32K 砍到 8K，对于单卡跑 31B 这是比较合理的上限
MAX_NUM_BATCHED_TOKENS=4096     # 必须与 MAX_MODEL_LEN 匹配或略大，绝不能是 65536，否则启动必挂
MAX_NUM_SEQS=1


ENABLE_ASYNC_SCHEDULING=1
GENERATION_CONFIG=vllm
# 当 DEPLOY_PROFILE=benchmark 时会自动开启
DISABLE_PREFIX_CACHING=0
# Gemma4 reasoning / tool calling 开关（纯文本模式建议关闭）
ENABLE_REASONING=0
ENABLE_TOOL_CALLING=0
# 多卡时可设置, 单卡留空
TENSOR_PARALLEL_SIZE=
# 动态视觉分辨率等参数（JSON 字符串），例如 {"max_pixels":1280}
MM_PROCESSOR_KWARGS=
# 纯文本模式：完全跳过多模态分析
LIMIT_MM_PER_PROMPT='image=0 audio=0'

# Backend (assistant-bot) side
LLM_PROVIDER=vllm
VLLM_BASE_URL=http://127.0.0.1:6008/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=gemma4-31b-it-awq
