# AssistantBot Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_V1_PREFIX=/api
PROJECT_NAME=AssistantBot

# LLM Provider: llama_cpp | vllm
LLM_PROVIDER=llama_cpp

# Local llama.cpp model settings (used when LLM_PROVIDER=llama_cpp)
MODEL_PATH=./models/qwen2.5-7b-instruct-q3_k_m.gguf
N_GPU_LAYERS=-1
N_CTX=4096
F16_KV=true
CHAT_TEMPLATE_TYPE=qwen

# Remote vLLM settings (used when LLM_PROVIDER=vllm)
VLLM_BASE_URL=http://<YOUR_SERVER_IP>:8100/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=gemma4-e4b-it
VLLM_DEPLOY_PROFILE=rag_text
VLLM_TIMEOUT_SECONDS=60
VLLM_PROBE_TIMEOUT_SECONDS=4
VLLM_HEALTH_CACHE_SECONDS=15

# Multimodal safety guard (base64 chars, without data URL prefix)
MAX_IMAGE_BASE64_CHARS=4000000
# Legacy vision proxy settings (used only when LLM_PROVIDER!=vllm image proxy path)
VISION_BACKEND=glm
DISABLE_GLM_VISION=false
# Chat file attachment limits (for direct file reading in chat)
MAX_CHAT_FILE_BASE64_CHARS=8000000
MAX_CHAT_FILE_CONTEXT_CHARS=12000
CHAT_FILE_ALLOWED_EXTENSIONS=.txt,.md,.markdown,.pdf,.csv,.json,.log
# Document upload limits
MAX_UPLOAD_FILE_SIZE_MB=20
MAX_BATCH_UPLOAD_FILES=10
UPLOAD_ALLOWED_EXTENSIONS=.txt,.md,.markdown,.html,.htm,.pdf

# Generation Parameters
TEMPERATURE=0.1
MAX_TOKENS=512
TOP_P=0.95
TOP_K=40

# Embedding Settings
EMBEDDING_MODEL=thenlper/gte-large
EMBEDDING_DEVICE=mps
# Disable HF tokenizer parallelism in fork/reload mode (recommended)
TOKENIZERS_PARALLELISM=false

# ChromaDB Settings
CHROMA_PERSIST_DIR=./data/chroma_db

# External APIs (Optional)
METAPHOR_API_KEY=
OPENAI_API_KEY=
